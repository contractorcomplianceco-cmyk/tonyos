# TonyOS Command Center — environment template
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# Only DATABASE_URL is a secret; the rest are infra/config and frontend-safe.

# ── Required ─────────────────────────────────────────────────────────────
# Postgres connection string. SECRET. Use a managed Postgres (e.g. AWS RDS,
# Supabase). Do NOT use the Replit-managed database as production source of truth.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the service binds to. Set per service (the API and each web app need
# their own). On AWS this is typically set by your process manager / nginx.
PORT=8080

# Base path the web app is served under at BUILD time (frontend-safe).
# Use "/" when served at the domain root.
BASE_PATH=/

# ── Optional ─────────────────────────────────────────────────────────────
# development | production
NODE_ENV=development

# API log level: info | debug | warn | error
LOG_LEVEL=info

# Production CORS allowlist — comma-separated origins. Leave UNSET only in
# local dev (unset = allow all origins). MUST be set before public deployment.
# CORS_ORIGIN=https://tonyos.example.com,https://admin.tonyos.example.com

# NOTE: REPL_ID is Replit-only and auto-injected on Replit. Do NOT set it on
# AWS/Cursor — it gates Replit-only dev Vite plugins.
